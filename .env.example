# ------------------------------------------------------------------------------
# Uptime Monitor - Environment Template
# Copy to `.env` and replace placeholder values before running in production.
# Do not commit real secrets.
# NOTE: `scripts/ssl_monitor.py` does not read `.env`; it uses shell environment
# variables (local) or GitHub Actions Secrets (CI) directly.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Application / Runtime
# ------------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
LOG_ENABLE=false
# Required when LOG_ENABLE=true (example: logs/uptime-monitor.log)
LOG_FILE=
# HTTP binding for Web-Service platforms (Render):
# WEB_PORT takes precedence. If empty, app uses PORT, then defaults to 10000.
WEB_BIND_HOST=0.0.0.0
WEB_PORT=
HEALTH_PATH=/healthz

# Per-check timeout in seconds (float supported, e.g., 3.5)
TIMEOUT_SECONDS=5

# Retry policy for each target check
RETRY_COUNT=3
RETRY_BACKOFF_BASE_SECONDS=0.5

# Scheduler interval for continuous mode
CHECK_INTERVAL_MINUTES=5

# Comma-separated fallback ports for TCP checks
DEFAULT_TCP_PORTS=80,443

# HTTP/HTTPS request settings
HTTP_PATH=/
USER_AGENT=uptime-monitor/1.0

# ------------------------------------------------------------------------------
# Monitoring Behavior Toggles
# ------------------------------------------------------------------------------
ENABLE_ICMP=true
ENABLE_TCP_FALLBACK=true
ENABLE_HTTP_FALLBACK=true

# Max parallel checks (threads/workers)
MAX_WORKERS=10

# Max number of rows printed in terminal summary
SUMMARY_LIMIT=20

# Database credentials and connection parameters
DB_USER=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_HOST=REPLACE_WITH_DB_HOST
DB_PORT=REPLACE_WITH_DB_PORT
DB_NAME=REPLACE_WITH_DB_NAME

# Optional DB behavior tuning
DB_POOL_SIZE=5
DB_CONNECT_TIMEOUT=10

# ------------------------------------------------------------------------------
# Database Security / TLS (set for remote DBs as needed)
# Keep blank unless your DB environment requires SSL/TLS.
# ------------------------------------------------------------------------------
DB_SSL_MODE=
DB_SSL_CA=
DB_SSL_CERT=
DB_SSL_KEY=

# ------------------------------------------------------------------------------
# Schema/Table Indirection
# Use these to map to existing DB naming conventions without code hardcoding.
# ------------------------------------------------------------------------------
TABLE_SERVERS=monitored_servers
TABLE_CHECKS=uptime_check_history

# Servers table columns
COL_SERVERS_ID=id
COL_SERVERS_TARGET=target
COL_SERVERS_TARGET_TYPE=target_type
COL_SERVERS_IS_ACTIVE=is_active
COL_SERVERS_CREATED_AT=created_at
COL_SERVERS_UPDATED_AT=updated_at

# Checks/history table columns
COL_CHECKS_ID=id
COL_CHECKS_SERVER_ID=server_id
COL_CHECKS_TARGET=target
COL_CHECKS_TIMESTAMP=checked_at
COL_CHECKS_STATUS=status
COL_CHECKS_RESPONSE_TIME_MS=response_time_ms
COL_CHECKS_ERROR_DETAILS=error_details
COL_CHECKS_CHECK_METHOD=check_method

# ------------------------------------------------------------------------------
# Notes
# - Status is typically "up" or "down".
# - Target type is typically "domain", "ipv4", or "ipv6".
# - Keep core uptime-monitor secrets in local `.env` only (never commit).
# - SSL monitor secrets should be injected as environment variables or GitHub Secrets.
# ------------------------------------------------------------------------------
