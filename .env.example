# ------------------------------------------------------------------------------
# Monitoring Utilities - Environment Template
# Copy to `.env` for local reference only. Do not commit real secrets.
#
# Important:
# - scripts/monthly_uptime_report.py and scripts/ssl_monitor.py read process
#   environment variables directly.
# - They do not auto-load `.env` by themselves.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Monthly UptimeRobot Report (scripts/monthly_uptime_report.py)
# ------------------------------------------------------------------------------
UPTIMEROBOT_API_TOKEN=REPLACE_WITH_UPTIMEROBOT_READ_TOKEN

# ------------------------------------------------------------------------------
# Monthly SSL Monitor (scripts/ssl_monitor.py)
# Supports SERVER1_*, SERVER2_*, ... aliases.
# ------------------------------------------------------------------------------
SERVER1_HOST=REPLACE_WITH_SERVER_HOST
SERVER1_PORT=22
SERVER1_USER=REPLACE_WITH_SERVER_USER
SERVER1_PASSWORD=REPLACE_WITH_SERVER_PASSWORD

# Optional additional servers (duplicate and increment index):
# SERVER2_HOST=
# SERVER2_PORT=22
# SERVER2_USER=
# SERVER2_PASSWORD=

SMTP_HOST=REPLACE_WITH_SMTP_HOST
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
EMAIL_FROM=monitoring@example.com
EMAIL_TO=ops@example.com
